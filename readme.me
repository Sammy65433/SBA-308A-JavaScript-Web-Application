Steps 1 - Lets see if we can get data 

Handle API REQUEST 
Api.js
Make a request / await - Fetch / check for errors  Template literals / convert to Json 

export async function getTeams() {
  const resp = await fetch('https://api.balldontlie.io/v1/teams');
  if (!resp.ok) throw new Error(`Failed ${resp.status}`);
  const data = await resp.json();               // MDN: Response.json()
  return data.data;                             // array of team objects
}

